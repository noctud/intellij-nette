<idea-plugin>
    <id>org.nette.helpers</id>
    <name>Nette</name>
    <vendor>Noctud.dev</vendor>

    <!-- http://confluence.jetbrains.com/display/IDEADEV/Build+Number+Ranges -->
    <idea-version/>

    <depends>com.intellij.modules.lang</depends>
    <depends>com.jetbrains.php</depends>

    <extensions defaultExtensionNs="com.jetbrains.php">
        <typeProvider4 implementation="dev.noctud.nette.typeProvider.ControlTypeProvider"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <implicitUsageProvider implementation="dev.noctud.nette.usageProvider.ComponentImplicitUsageProvider"/>
        <completion.contributor language="PHP" implementationClass="dev.noctud.nette.completion.ControlCompletionContributor"/>
        <completion.contributor language="PHP" implementationClass="dev.noctud.nette.completion.LinkCompletionContributor"/>
        <psi.referenceContributor language="PHP" implementation="dev.noctud.nette.reference.LinkReferenceContributor"/>
        <annotator language="PHP" implementationClass="dev.noctud.nette.annotator.LinkAnnotator"/>
        <referencesSearch implementation="dev.noctud.nette.search.LinkReferencesSearcher"/>
        <renameHandler implementation="dev.noctud.nette.reference.LinkRenameVetoHandler" order="first"/>
    </extensions>
</idea-plugin>
